# 数据库配置（Docker 内部使用服务名）
DATABASE_URL=mysql+pymysql://root:root@mysql:3306/timerservice?charset=utf8mb4

# JWT 密钥（生产环境请修改为随机字符串）
JWT_SECRET=production-secret-key-change-me

# JWT 过期时间（秒，默认 24 小时）
JWT_EXPIRES_SECONDS=86400

# 服务器时区
SERVER_TZ=Asia/Shanghai

# Flask 配置
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_ENV=production

# Flask Secret Key
FLASK_SECRET_KEY=production-flask-secret-key-change-me
# 数据库配置
DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/timerservice?charset=utf8mb4

# JWT 密钥（请修改为随机字符串）
JWT_SECRET=change-this-to-a-random-secret-key-at-least-32-characters-long

# JWT 过期时间（秒，默认 24 小时）
JWT_EXPIRES_SECONDS=86400

# 服务器时区
SERVER_TZ=Asia/Shanghai

# Flask 配置
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_ENV=development

# Flask Secret Key
FLASK_SECRET_KEY=your-flask-secret-key-change-in-production
